---
import { getCollection, render } from "astro:content";
import { Image } from "astro:assets";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Nav from "../../components/Nav.astro";
import Lightbox from "../../components/mdx/Lightbox.astro";
import NewsletterSection from "../../components/NewsletterSection.astro";
import Footer from "../../components/Footer.astro";

export async function getStaticPaths() {
  const posts = await getCollection("kronika");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const title = `${post.data.title} | Šachy Lysice`;
const description = post.data.intro;
---

<BaseLayout title={title} description={description}>
  <Nav />

  <main>
    <article class="section">
      <div class="container flow-lg">
        <a href="/kronika" class="back-link">← Zpět na kroniku</a>

        <header class="article-header">
          <time datetime={post.data.date.toISOString()}>
            {post.data.date.toLocaleDateString("cs-CZ", {
              year: "numeric",
              month: "long",
              day: "numeric",
            })}
          </time>
          <h1>{post.data.title}</h1>
        </header>

        <div class="kronika-content" data-lightbox>
          <Content />
        </div>
      </div>
    </article>
  </main>

  <Lightbox />
  <NewsletterSection />
  <Footer />
</BaseLayout>

<style>
  .back-link {
    display: inline-block;
    font-size: 0.9rem;
    color: var(--color-accent, #8b6914);
    text-decoration: none;
    margin-bottom: 1rem;
  }

  .back-link:hover {
    text-decoration: underline;
  }

  .article-header {
    margin-bottom: 2rem;
  }

  .article-header time {
    display: block;
    font-size: 0.9rem;
    color: var(--color-muted, #7a6f60);
    margin-bottom: 0.5rem;
    text-transform: capitalize;
  }

  .article-header h1 {
    font-size: clamp(1.5rem, 4vw, 2.5rem);
    line-height: 1.2;
  }

  /* Article content typography */
  .kronika-content :global(h2) {
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }

  .kronika-content :global(h3),
  .kronika-content :global(h4) {
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  .kronika-content :global(p) {
    margin-bottom: 1.25rem;
  }

  .kronika-content :global(ul),
  .kronika-content :global(ol) {
    margin-bottom: 1.25rem;
    padding-left: 1.5rem;
  }

  .kronika-content :global(li + li) {
    margin-top: 0.4rem;
  }

  .kronika-content :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border, #e8e2d8);
    margin-block: 3rem;
  }

  .kronika-content :global(figure) {
    margin-block: 1.5rem;
  }

  .kronika-content :global(blockquote) {
    border-left: 4px solid var(--color-accent, #8b6914);
    padding-left: 1.25rem;
    color: var(--color-text-secondary, #5a4d3a);
    font-style: italic;
    margin-block: 1.5rem;
  }
</style>
