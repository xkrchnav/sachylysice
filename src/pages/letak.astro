---
import { Image } from "astro:assets";
import vejceSachy from "../assets/images/jarni/vejceSachy.jpeg";
import qrSachylysice from "../assets/images/qr-sachylysice.png";
---

<!doctype html>
<html lang="cs">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <title>Leták – Jarní šachové probuzení 2026 | Šachy Lysice</title>
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      :root {
        --green-ink: #1b5e3a;
        --green-deep: #0f3f28;
        --sun-gold: #e7b32a;
        --sun-soft: #f6e8b6;
        --ink: #1a1a1a;
      }

      body {
        background: radial-gradient(circle at top, #f5fbf2 0%, #e6efe7 40%, #e8e8e8 100%);
        font-family: "Palatino Linotype", "Book Antiqua", Palatino, serif;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1.5rem;
        padding: 2rem 1rem;
        min-height: 100vh;
      }

      /* ── screen-only ── */
      .screen-controls {
        display: flex; gap: 1rem; align-items: center;
        flex-wrap: wrap; justify-content: center;
      }
      .btn {
        background: var(--green-ink); color: #fff; border: none;
        padding: .65rem 1.6rem; font-size: 1rem; border-radius: 6px;
        cursor: pointer; font-family: inherit; text-decoration: none;
        display: inline-block;
      }
      .btn:hover { background: #2f7a50; }
      .btn--secondary { background: #555; }
      .btn--secondary:hover { background: #333; }
      .hint {
        font-size: .85rem; color: #555; font-family: sans-serif;
        text-align: center; max-width: 36rem;
      }
      .link-btn {
        background: none; border: none; padding: 0; margin: 0;
        color: var(--green-ink); font: inherit; cursor: pointer;
        text-decoration: none; font-weight: bold;
      }
      .link-btn:hover { text-decoration: underline; }

      /* ── A4 landscape sheet ── */
      .a4-sheet {
        width: 297mm; height: 210mm; background: #fff;
        display: flex; position: relative;
        box-shadow: 0 4px 24px rgba(0,0,0,.25);
        overflow: hidden; print-color-adjust: exact;
        -webkit-print-color-adjust: exact;
      }
      .a4-sheet::after {
        content: "✂"; position: absolute;
        left: 50%; top: 50%; transform: translate(-50%, -50%);
        font-size: 1rem; color: #bbb; z-index: 10;
      }
      .cut-line {
        position: absolute; left: 50%; top: 0; bottom: 0;
        width: 0; border-left: 1.5px dashed #ccc; z-index: 5;
      }

      /* ── A5 flyer ── */
      .flyer {
        width: 148.5mm; height: 210mm;
        display: flex; flex-direction: column;
        overflow: hidden; background: #fff; color: var(--ink);
      }

      /* ── hero (pure photo) ── */
      .flyer__hero {
        position: relative; flex-shrink: 0;
        height: 68mm; overflow: hidden;
        display: flex; flex-direction: column;
        justify-content: flex-end;
      }
      .flyer__hero-img {
        position: absolute; top: 0; left: 0; width: 100%; height: 100%;
        object-fit: cover; object-position: center 35%;
        display: block;
      }
      .flyer__chess-stripe {
        position: relative; z-index: 2;
        display: flex; height: 4.2mm; flex-shrink: 0;
      }
      .flyer__chess-stripe span { flex: 1; }
      .flyer__chess-stripe span:nth-child(odd)  { background: rgba(255,255,255,.8); }
      .flyer__chess-stripe span:nth-child(even) { background: rgba(11, 43, 28, .65); }

      /* ── header (text below image) ── */
      .flyer__header {
        display: flex; flex-direction: column;
        align-items: center; justify-content: center;
        padding: 2mm 5mm 0mm; text-align: center;
        background: #fff;
      }
      .flyer__eyebrow {
        font-family: "Palatino Linotype", "Book Antiqua", Palatino, serif; font-size: 16pt; font-weight: 900;
        letter-spacing: .25em; text-transform: uppercase;
        color: var(--green-ink); margin-bottom: 1mm;
      }
      .flyer__title { line-height: 1; color: var(--ink); }
      .flyer__title-sub {
        display: block; font-size: 36pt; font-weight: bolder;
        font-family: "Palatino Linotype", "Book Antiqua", Palatino, serif;
        letter-spacing: .05em; text-transform: uppercase;
        color: var(--ink); 
        margin-bottom: 1mm;
      }
      .flyer__title-main {
        display: block; font-size: 22pt; font-weight: bold;
        font-family: "Palatino Linotype", "Book Antiqua", Palatino, serif;
        text-transform: uppercase; letter-spacing: .15em;
        color: var(--green-deep);
        line-height: 1; margin-bottom: 1.5mm;
      }
      .flyer__title-year {
        display: block; font-size: 14pt; font-weight: bold;
        font-family: "Palatino Linotype", "Book Antiqua", Palatino, serif;
        color: var(--sun-gold); letter-spacing: .3em;
      }

      /* ── body info ── */
      .flyer__body {
        flex: 1; padding: 4mm 6mm 2mm;
        display: flex; flex-direction: column; gap: 2.5mm;
      }
      .flyer__tagline {
        font-size: 11pt; font-weight: bold; color: var(--green-deep);
        border-left: 4px solid var(--sun-gold);
        padding-left: 4mm; margin-bottom: 1mm; line-height: 1.3;
      }
      .info-grid {
        display: grid; grid-template-columns: auto 1fr;
        gap: 3mm 4mm; font-size: 11pt;
      }
      .info-grid dt {
        font-weight: bold; color: var(--green-ink);
        white-space: nowrap; font-family: sans-serif; font-size: 10pt;
      }
      .info-grid dd { color: var(--ink); font-size: 12pt; line-height: 1.4; }
      .info-grid dd strong { font-size: 14pt; }
      .flyer__cta {
        margin-top: 1mm; padding: 3mm 4mm; border-radius: 6px;
        background: linear-gradient(90deg, var(--sun-soft), #fff8d8);
        color: var(--green-deep); font-family: sans-serif; font-size: 10pt;
        display: flex; align-items: center; justify-content: space-between; gap: 3mm;
      }
      .flyer__cta strong {
        color: var(--green-ink); font-size: 13pt; letter-spacing: .03em;
      }
      .flyer__note {
        font-size: 7.5pt; color: #5b5b5b; font-family: sans-serif;
        line-height: 1.4; border-top: 1px solid #eee;
        padding-top: 2mm; margin-top: auto;
      }

      /* ── footer ── */
      .flyer__footer {
        background: #0f2f20; color: #fff;
        display: flex; align-items: center; justify-content: center;
        padding: 2.5mm 4mm; gap: 1.5mm; flex-shrink: 0;
        print-color-adjust: exact;
        -webkit-print-color-adjust: exact;
      }
      .flyer__qr-block {
        display: flex; flex-direction: column; align-items: center; gap: 1mm;
      }
      .flyer__qr-block img {
        width: 18mm; height: 18mm; display: block;
        background: #fff; border-radius: 3px;
      }
      .flyer__qr-label {
        font-family: sans-serif; font-size: 5.5pt;
        color: #aaa; letter-spacing: .05em;
      }

      /* ── A4 portrait sheet ── */
      .a4-sheet-full {
        width: 210mm; height: 297mm; background: #fff;
        display: flex; flex-direction: column; position: relative;
        box-shadow: 0 4px 24px rgba(0,0,0,.25);
        overflow: hidden; print-color-adjust: exact;
        -webkit-print-color-adjust: exact;
      }

      /* ── Full-page A4 flyer ── */
      .flyer-a4 {
        width: 100%; height: 100%;
        display: flex; flex-direction: column;
        overflow: hidden; background: #fff; color: var(--ink);
      }

      .flyer-a4 .flyer__hero {
        position: relative; flex-shrink: 0;
        height: 90mm; overflow: hidden;
        display: flex; flex-direction: column;
        justify-content: flex-end;
      }

      .flyer-a4 .flyer__chess-stripe {
        height: 5mm;
      }

      .flyer-a4 .flyer__header {
        display: flex; flex-direction: column; align-items: center; text-align: center;
        padding: 3mm 10mm 1mm;
      }

      .flyer-a4 .flyer__eyebrow {
        font-size: 20pt;
        margin-bottom: 1.5mm;
      }

      .flyer-a4 .flyer__title-sub {
        font-size: 48pt;
        margin-bottom: 1.5mm;
      }

      .flyer-a4 .flyer__title-main {
        font-size: 30pt;
        margin-bottom: 2mm;
      }

      .flyer-a4 .flyer__title-year {
        font-size: 20pt;
      }

      .flyer-a4 .flyer__body {
        flex: 1; padding: 5mm 10mm 2mm;
        gap: 2.5mm;
      }

      .flyer-a4 .flyer__tagline {
        font-size: 12pt;
        padding-left: 6mm;
        margin-bottom: 0;
      }

      .flyer-a4 .info-grid {
        gap: 3.5mm 6mm; font-size: 13pt;
      }

      .flyer-a4 .info-grid dt {
        font-size: 11pt;
      }

      .flyer-a4 .info-grid dd {
        font-size: 13pt;
      }

      .flyer-a4 .info-grid dd strong {
        font-size: 15pt;
      }

      .flyer-a4 .flyer__cta {
        padding: 4mm 8mm; font-size: 11pt;
      }

      .flyer-a4 .flyer__cta strong {
        font-size: 14pt;
      }

      .flyer-a4 .flyer__note {
        font-size: 9pt;
        padding-top: 1.5mm;
        margin-top: auto;
        line-height: 1.3;
      }

      .flyer-a4 .flyer__footer {
        padding: 3mm 8mm;
      }

      .flyer-a4 .flyer__qr-block img {
        width: 26mm; height: 26mm;
      }

      .flyer-a4 .flyer__qr-label {
        font-size: 7pt;
      }

      /* ── separator section ── */
      .flyer-section {
        text-align: center; padding: 3rem 2rem;
        background: #f5f5f5; color: #666;
        font-family: sans-serif; font-size: 0.95rem;
      }

      .flyer-section h3 {
        color: #333; margin-bottom: 0.7rem;
        font-size: 1.3rem;
      }

      .flyer-section p {
        margin-bottom: 0.5rem;
      }

      .flyer-section a {
        color: var(--green-ink); text-decoration: none; font-weight: bold;
      }

      .flyer-section a:hover {
        text-decoration: underline;
      }

      /* ── print ── */
      @media print {
        @page { margin: 0; }
        html, body {
          background: #fff; padding: 0; margin: 0;
          display: block; width: 100%; height: auto;
        }
        .screen-controls, .hint, .flyer-section { display: none !important; }
        .a4-sheet {
          box-shadow: none;
          width: 100vw; height: 100vh;
          page-break-inside: avoid;
          page-break-after: always;
        }
        .a4-sheet .flyer {
          width: 50%; height: 100%;
        }
        .a4-sheet-full {
          box-shadow: none;
          width: 100vw; height: 100vh;
          page-break-inside: avoid;
          page-break-after: always;
        }
        .a4-sheet-full .flyer-a4 {
          width: 100%; height: 100%;
        }
        /* Fixed hero height for consistent print layout */
        .flyer__hero {
          height: 68mm;
        }
        .flyer-a4 .flyer__hero {
          height: 90mm;
        }
      }
    </style>
  </head>
  <body>

    <div class="screen-controls">
      <button class="btn" onclick="printA5()">🖨 Tisk A5 (2x)</button>
      <button class="btn" onclick="printA4()">🖨 Tisk A4 (1x)</button>
      <a class="btn" href="/letak-a5.pdf" download>📥 PDF A5 (2x)</a>
      <a class="btn" href="/letak-a4.pdf" download>📥 PDF A4 (1x)</a>
      <a class="btn btn--secondary" href="/">← Zpět na web</a>
    </div>
    <p class="hint">
      <strong>Leták A5:</strong> Dva letáčky vedle sebe na formátu A4 na šíř – vytiskněte, přeložte a nastřihněte.<br />
      <strong>Leták A4:</strong> Jeden větší leták na celou stránku – ideální pro nástěnku. <button type="button" class="link-btn" onclick="document.querySelector('.a4-sheet-full').scrollIntoView({behavior: 'smooth'})">Přejít na A4 leták ↓</button>
    </p>

    <div class="a4-sheet">
      <div class="cut-line"></div>

      {[1, 2].map(() => (
        <article class="flyer">
          <div class="flyer__hero">
            <Image src={vejceSachy} alt="Šachové vejce – jarní turnaj" width={800} quality={90} class="flyer__hero-img" loading="eager" />
            <div class="flyer__chess-stripe">
              {Array.from({ length: 14 }).map(() => <span />)}
            </div>
          </div>
          <div class="flyer__header">
            <p class="flyer__eyebrow">Šachy · Lysice</p>
            <h1 class="flyer__title">
              <span class="flyer__title-sub">Jarní šachové</span>
              <span class="flyer__title-main">Probuzení</span>
              <span class="flyer__title-year">✦ 12.4.2026 ✦</span>
            </h1>
          </div>

          <div class="flyer__body">
            <p class="flyer__tagline">Jarní setkání u šachovnice pro každého.</p>

            <dl class="info-grid">
              <dt>📅 Kdy</dt>
              <dd><strong>Neděle 12. 4. 2026</strong></dd>
              <dt>⏰ Čas</dt>
              <dd>10:00 – 18:00</dd>
              <dt>📍 Kde</dt>
              <dd>Lysické Jablíčko, Lysice</dd>
            </dl>

            <div class="flyer__cta">
              <span>📲 Přihláška SMS</span>
              <strong>777 347 591</strong>
            </div>

            <p class="flyer__note">
              Otevřené pro začátečníky i zkušené hráče. Vstupné dobrovolné. 🍏
            </p>
          </div>

          <footer class="flyer__footer">
            <div class="flyer__qr-block">
              <Image src={qrSachylysice} alt="QR kód na web sachylysice.cz" width={140} height={140} loading="eager" />
              <span class="flyer__qr-label">více info na www.sachylysice.cz</span>
            </div>
          </footer>
        </article>
      ))}
    </div>

    <!-- ── SEPARATOR & DESCRIPTION ── -->
    <div class="flyer-section">
      <h3>📄 Leták A4 – Pro nástěnku a větší tisk</h3>
      <p>Leták v plné velikosti formátu A4. Ideální pro vytisknutí na opravu a umístění na úřední desku, do kaváren či do kulturních domů.</p>
      <p style="margin-top: 1rem; font-size: 0.9rem; color: #888;">
        👉 Níže naleznete verzi A4 pro tisk a sdílení.
      </p>
    </div>

    <!-- ── A4 FULL-PAGE FLYER ── -->
    <div class="a4-sheet-full">
      <article class="flyer flyer-a4">
        <div class="flyer__hero">
            <Image src={vejceSachy} alt="Šachové vejce – jarní turnaj" width={800} quality={90} class="flyer__hero-img" loading="eager" />
            <div class="flyer__chess-stripe">
              {Array.from({ length: 14 }).map(() => <span />)}
            </div>
          </div>
          <div class="flyer__header">
            <p class="flyer__eyebrow">Šachy · Lysice</p>
            <h1 class="flyer__title">
              <span class="flyer__title-sub">Jarní šachové</span>
              <span class="flyer__title-main">Probuzení</span>
              <span class="flyer__title-year">✦ 12.4.2026 ✦</span>
            </h1>
          </div>

        <div class="flyer__body">
          <p class="flyer__tagline">Jarní setkání u šachovnice pro každého. Přijďte si zahrát bez ohledu na úroveň!</p>

          <dl class="info-grid">
            <dt>📅 Kdy</dt>
            <dd><strong>Neděle 12. 4. 2026</strong></dd>
            <dt>⏰ Čas</dt>
            <dd>10:00 – 18:00</dd>
            <dt>📍 Kde</dt>
            <dd>Lysické Jablíčko, Lysice</dd>
            <dt>🏆 Systém</dt>
            <dd>Švýcarský – férový pro všechny</dd>
            <dt>🌐 Více info</dt>
            <dd><strong>www.sachylysice.cz</strong></dd>
          </dl>

          <div class="flyer__cta">
            <span>📲 Přihláška SMS</span>
            <strong>777 347 591</strong>
          </div>

          <p class="flyer__note">
            Turnaj je otevřený všem – začátečníkům i zkušeným hráčům. Švýcarský systém zajistí, že si vždy zahrajete s někým podobné úrovně. Vstupné dobrovolné. 🍏
          </p>
        </div>

        <footer class="flyer__footer">
            <div class="flyer__qr-block">
              <Image src={qrSachylysice} alt="QR kód na web sachylysice.cz" width={140} height={140} loading="eager" />
              <span class="flyer__qr-label">více info na www.sachylysice.cz</span>
            </div>
          </footer>
      </article>
    </div>

    <!-- ── BACK LINK ── -->
    <div style="margin-top: 2rem; text-align: center;">
      <a class="btn btn--secondary" href="/">← Zpět na hlavní web</a>
    </div>

    <script is:inline>
      function printA5() {
        var style = document.createElement('style');
        style.textContent = '@page { size: landscape; }';
        document.head.appendChild(style);

        var a4SheetFull = document.querySelector('.a4-sheet-full');
        var flyerSection = document.querySelector('.flyer-section');
        var backLink = document.querySelector('div[style*="margin-top: 2rem"]');
        var screenControls = document.querySelector('.screen-controls');
        var hint = document.querySelector('.hint');
      
        if (a4SheetFull) a4SheetFull.style.display = 'none';
        if (flyerSection) flyerSection.style.display = 'none';
        if (backLink) backLink.style.display = 'none';
        if (screenControls) screenControls.style.display = 'none';
        if (hint) hint.style.display = 'none';
      
        window.print();
      
        if (a4SheetFull) a4SheetFull.style.display = '';
        if (flyerSection) flyerSection.style.display = '';
        if (backLink) backLink.style.display = '';
        if (screenControls) screenControls.style.display = '';
        if (hint) hint.style.display = '';

        document.head.removeChild(style);
      }
    
      function printA4() {
        var style = document.createElement('style');
        style.textContent = '@page { size: portrait; }';
        document.head.appendChild(style);

        var a4Sheet = document.querySelector('.a4-sheet');
        var flyerSection = document.querySelector('.flyer-section');
        var backLink = document.querySelector('div[style*="margin-top: 2rem"]');
        var screenControls = document.querySelector('.screen-controls');
        var hint = document.querySelector('.hint');
      
        if (a4Sheet) a4Sheet.style.display = 'none';
        if (flyerSection) flyerSection.style.display = 'none';
        if (backLink) backLink.style.display = 'none';
        if (screenControls) screenControls.style.display = 'none';
        if (hint) hint.style.display = 'none';
      
        window.print();
      
        if (a4Sheet) a4Sheet.style.display = '';
        if (flyerSection) flyerSection.style.display = '';
        if (backLink) backLink.style.display = '';
        if (screenControls) screenControls.style.display = '';
        if (hint) hint.style.display = '';

        document.head.removeChild(style);
      }
    </script>
  </body>
</html>
