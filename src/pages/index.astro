<script>
  const initNewsletterForm = () => {
    const form = document.querySelector("#newsletter-form");
    const emailInput = document.querySelector("#email-input");
    const consentInput = document.querySelector("#consent-input");
    const messageDiv = document.querySelector("#form-message");

    // Check if all required elements exist
    if (
      !(form instanceof HTMLFormElement) ||
      !(emailInput instanceof HTMLInputElement) ||
      !(consentInput instanceof HTMLInputElement) ||
      !(messageDiv instanceof HTMLDivElement)
    ) {
      console.error("Newsletter form elements not found");
      return;
    }

    // Czech validation messages
    emailInput.addEventListener("invalid", () => {
      if (emailInput.validity.valueMissing) {
        emailInput.setCustomValidity("Prosím vyplňte e-mail.");
      } else if (emailInput.validity.typeMismatch) {
        emailInput.setCustomValidity(
          "Prosím zadejte platnou e-mailovou adresu.",
        );
      }
    });

    emailInput.addEventListener("input", () => {
      emailInput.setCustomValidity("");
    });

    consentInput.addEventListener("invalid", () => {
      consentInput.setCustomValidity(
        "Musíte souhlasit se zpracováním osobních údajů.",
      );
    });

    consentInput.addEventListener("change", () => {
      consentInput.setCustomValidity("");
    });

    form.addEventListener("submit", async (e) => {
      e.preventDefault();

      const submitButton = form.querySelector('button[type="submit"]');
      if (!(submitButton instanceof HTMLButtonElement)) {
        console.error("Submit button not found");
        return;
      }

      const originalText = submitButton.textContent;
      submitButton.disabled = true;
      submitButton.textContent = "Odesílám...";
      messageDiv.style.display = "none";

      const formData = new FormData(form);
      const APPS_SCRIPT_URL =
        "https://script.google.com/macros/s/AKfycbywrEfS95SVZUi-DHN3cHuTGNixfcUj3um3ZWiPLR3HyeD9oZ5yn6MAIZvZiXAlZjt6/exec";

      try {
        const response = await fetch(APPS_SCRIPT_URL, {
          method: "POST",
          body: formData,
        });

        const result = await response.json();

        messageDiv.style.display = "block";
        if (result.status === "success") {
          messageDiv.style.color = "#10b981";
          messageDiv.textContent = result.message;
          form.reset();
        } else {
          messageDiv.style.color = "#ef4444";
          messageDiv.textContent = result.message;
        }
      } catch (error) {
        messageDiv.style.display = "block";
        messageDiv.style.color = "#ef4444";
        messageDiv.textContent = "Chyba při odesílání. Zkuste prosím znovu.";
        console.error("Form submission error:", error);
      } finally {
        submitButton.disabled = false;
        submitButton.textContent = originalText;
      }
    });
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initNewsletterForm, {
      once: true,
    });
  } else {
    initNewsletterForm();
  }
</script>

<style>
  .form-error {
    display: block;
    color: #ef4444;
    font-size: 0.875rem;
    margin-top: 0.25rem;
    margin-bottom: 0.75rem;
  }
</style>
