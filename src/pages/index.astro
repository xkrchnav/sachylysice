---
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import Hero from "../components/Hero.astro";
import AboutSection from "../components/AboutSection.astro";
import SpringTournament from "../components/SpringTournament.astro";
import ArchiveSection from "../components/ArchiveSection.astro";
import NewsletterSection from "../components/NewsletterSection.astro";
import Footer from "../components/Footer.astro";

const title = "Šachy Lysice";
const description =
  "Sousedské šachy v zámeckých Lysicích. Hrajeme pro radost a setkání.";
---

<BaseLayout title={title} description={description}>
  <Nav />

  <main>
    <Hero />
    <AboutSection />
    <SpringTournament />
    <ArchiveSection />
  </main>

  <NewsletterSection />
  <Footer />
</BaseLayout>
