---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Image } from "astro:assets";

/* ── Local image imports for Astro optimization ── */
import logo from "../assets/images/logo.png";
import vejceSachy from "../assets/images/jarni/vejceSachy.jpeg";
import tournamentTable from "../assets/images/image02.jpg";
import finaleGroup from "../assets/images/image03.jpg";

/* Gallery 1 – Lidový dům */
import g1_entry from "../assets/images/gallery01/b04ca2f7_original.jpg";
import g1_drawing from "../assets/images/gallery01/741cb371_original.jpg";
import g1_players from "../assets/images/gallery01/da165b68_original.jpg";
import g1_sweat from "../assets/images/gallery01/09210abf_original.jpg";

/* Gallery 2 – Zámecké finále */
import g2_castle from "../assets/images/gallery02/baa13a13_original.jpg";
import g2_kings from "../assets/images/gallery02/cc32a857_original.jpg";
import g2_duel from "../assets/images/gallery02/dc1a212c_original.jpg";
import g2_revenge from "../assets/images/gallery02/e1f75977_original.jpg";

/* Gallery 3 – Výsledky */
import g3_diplomas from "../assets/images/gallery03/7704571f_original.jpg";
import g3_poster from "../assets/images/gallery03/dd9ff495_original.jpg";
import g3_winner from "../assets/images/gallery03/2ee2cbd2_original.jpg";

const title = "Šachy Lysice";
const description =
  "Sousedské šachy v zámeckých Lysicích. Hrajeme pro radost a setkání.";
---

<BaseLayout title={title} description={description}>
  <!-- ════════════════════════════════════════
       NAVIGATION
       ════════════════════════════════════════ -->
  <nav class="site-nav" aria-label="Hlavní navigace">
    <div class="container site-nav__inner">
      <a href="/" class="site-nav__brand">♟ Šachy Lysice</a>
      <ul class="site-nav__links">
        <li><a href="#o-nas">O nás</a></li>
        <li><a href="#jarni-turnaj">Jarní turnaj</a></li>
        <li><a href="#archiv">Archiv</a></li>
        <li><a href="#kontakt">Kontakt</a></li>
      </ul>
    </div>
  </nav>

  <main>
    <!-- ════════════════════════════════════════
         HERO
         ════════════════════════════════════════ -->
    <section class="hero" aria-labelledby="hero-title">
      <div class="container flow">
        <Image
          src={logo}
          alt="Logo Šachy Lysice"
          width={240}
          class="hero__logo"
          loading="eager"
        />
        <h1 id="hero-title" class="hero__title">Šachy Lysice</h1>
        <h2 class="hero__subtitle">Vítejte u šachovnice v&nbsp;Lysicích</h2>
        <p class="hero__desc">
          Jsme komunita nadšenců, kteří věří, že šachy patří k&nbsp;životu
          v&nbsp;našem krásném zámeckém městysi stejně jako dobrá káva nebo
          nedělní procházka.
        </p>
      </div>
    </section>

    <!-- ════════════════════════════════════════
         O NÁS
         ════════════════════════════════════════ -->
    <section id="o-nas" class="section" aria-labelledby="about-title">
      <div class="container flow-lg">
        <h2 id="about-title">O co nám jde?</h2>
        <p>
          Spojujeme majestátnost „královské hry" s&nbsp;pohodou sousedského
          setkání. Nejde nám primárně o&nbsp;body a&nbsp;výkon, ale
          o&nbsp;radost ze hry.
        </p>

        <h3>Kdo k nám patří?</h3>
        <p>
          Všichni. U&nbsp;našich stolů (a občas i přímo na zámku!) jsou vítáni:
        </p>
        <ul class="steps">
          <li>♟️ Zkušení hráči, kteří můžou inspirovat.</li>
          <li>😊 Hobby hráči, kteří si chtějí jen tak zahrát.</li>
          <li>
            👀 Zvědaví začátečníci, kteří chtějí proniknout do tajů 64 polí.
          </li>
        </ul>

        <div class="highlight-box">
          <p>
            <strong>Pojďte s&nbsp;námi tvořit novou lysickou tradici.</strong>
          </p>
        </div>
      </div>
    </section>

    <!-- ════════════════════════════════════════
         JARNÍ ŠACHOVÝ TURNAJ 2026
         ════════════════════════════════════════ -->
    <section
      id="jarni-turnaj"
      class="section section--featured"
      aria-labelledby="spring-title"
    >
      <div class="container flow-lg">
        <div class="badge">📢 Aktuální turnaj</div>
        <h2 id="spring-title">Jarní šachový turnaj 2026</h2>

        <figure class="tournament-hero-img">
          <Image
            src={vejceSachy}
            alt="Jarní šachový turnaj – šachové vejce v lysických barvách"
            width={900}
          />
        </figure>

        <p>
          Nedávno jsem se u&nbsp;kulatého stolu od místních seniorů dozvěděl, že
          spousta z&nbsp;nich má doma šachovnici. Někteří klasickou dřevěnou,
          jiní dokonce skleněnou, často jen tak zaprášenou někde ve skříni nebo
          vystavenou na poličce. Příroda se na jaře probouzí, raší proutky,
          otevírají se pupeny… a&nbsp;já si říkám&nbsp;– pojďme toho využít
          a&nbsp;nechme letos na jaře vypučet a&nbsp;ožít i&nbsp;šachy
          u&nbsp;nás v&nbsp;Lysicích.
        </p>
        <p>
          Po předvánočním setkání vás proto zvu na
          <strong>jarní šachový turnaj</strong>. Záměrem je dostat tuto
          královskou hru opět do povědomí a&nbsp;přinést ji mezi lidi.
        </p>

        <div class="highlight-box">
          <h3>🙌 Nebojte se přijít!</h3>
          <p>
            Vůbec se nebojte, pokud nejste zkušení hráči. Doslova tu nejde
            o&nbsp;to vyhrát, ale zúčastnit se. Jde o&nbsp;to vyzkoušet si, jaké
            to je hrát na turnaji a&nbsp;nejen doma v&nbsp;obýváku. Hrát budeme
            tzv.&nbsp;<strong>švýcarským systémem</strong>. Ten chytře
            zajišťuje, že si proti sobě vždy zahrají hráči podobné úrovně.
            Turnaj tak bude férový a&nbsp;zábavný pro úplné amatéry, ale zachová
            si důstojnost i&nbsp;pro ostřílené šachisty.
          </p>
        </div>

        <p>
          Plně si uvědomuji, že je tu stále spousta „offline" obyvatel&nbsp;–
          a&nbsp;to je jedině dobře! Je to krásná příležitost k&nbsp;propojení
          generací. Budu proto velmi vděčný za každou pomoc s&nbsp;propagací
          turnaje i&nbsp;mimo internet. Pokud o&nbsp;akci řeknete svým sousedům,
          známým nebo rodině, moc mi tím pomůžete. Tištěné letáčky brzy donesu
          do Jednoty a&nbsp;na další místa v&nbsp;obci.
        </p>

        <p>
          Velké poděkování patří <strong>Lysickému Jablíčku</strong>, které nám
          laskavě poskytlo své prostory. 🍏
        </p>

        <div class="info-card">
          <h3>Základní informace</h3>
          <dl class="info-card__list">
            <div class="info-card__item">
              <dt>📅 Kdy</dt>
              <dd>Neděle 12.&nbsp;4.&nbsp;2026</dd>
            </div>
            <div class="info-card__item">
              <dt>⏰ Čas</dt>
              <dd>10:00 – 18:00</dd>
            </div>
            <div class="info-card__item">
              <dt>📍 Kde</dt>
              <dd>Lysické Jablíčko</dd>
            </div>
          </dl>
        </div>

        <div class="info-card info-card--action">
          <h3>Jak se přihlásit?</h3>
          <p>
            Klidně mi rovnou pošlete SMS na číslo
            <a href="sms:+420777347591"
              ><strong>777&nbsp;347&nbsp;591</strong></a
            >.
          </p>
        </div>

        <p class="cta-text">
          <strong
            >Přijďte si zahrát, popovídat si a&nbsp;strávit příjemnou jarní
            neděli nad černobílou deskou. Těšíme se&nbsp;na&nbsp;vás!</strong
          >
        </p>

        <div class="letak-promo">
          <p>📄 Pomozte šířit turnaj – vytiskněte a&nbsp;rozdejte letáček.</p>
          <a
            href="/letak"
            target="_blank"
            class="btn-letak"
            aria-label="Zobrazit a tisknout leták (otevře se v novém okně)"
            >Zobrazit &amp; tisknout leták →</a
          >
        </div>
      </div>
    </section>

    <!-- ════════════════════════════════════════
         ARCHIV AKCÍ
         ════════════════════════════════════════ -->
    <section
      id="archiv"
      class="section section--archive"
      aria-labelledby="archive-title"
    >
      <div class="container flow-lg">
        <h2 id="archive-title">Archiv akcí</h2>
        <p class="section-lead">
          Ohlédněte se s&nbsp;námi za tím, co už máme za sebou.
        </p>

        <!-- ── Předvánoční turnaj ── -->
        <details class="archive-event" open>
          <summary>
            <strong>🎄 První předvánoční turnaj</strong>
            <span class="archive-date">Prosinec 2025</span>
          </summary>
          <div class="archive-event__content flow-lg">
            <h4>Šachové oživení v&nbsp;Lysicích: Jak vzniká nová tradice</h4>

            <p>
              <strong
                >Když jsme se začátkem roku 2025 s&nbsp;rodinou přistěhovali do
                Lysic, jedna věc mi tu chyběla.</strong
              > V&nbsp;minulém bydlišti fungovala skvělá facebooková skupina, kde
              se neformálně informovalo a&nbsp;sdílelo. Zjistil jsem, že Lysice žádnou
              takovou neměly. Tak jsme ji s&nbsp;manželkou založili pod názvem „Lysice
              a&nbsp;okolí sobě". Taky jsem měl, v&nbsp;koutku duše, tajný sen: uspořádat
              šachový turnaj, nebo se rovnou pokusit o&nbsp;obnovu šachového života
              v&nbsp;obci.
            </p>

            <p>
              Při zjišťování terénu jsem sem tam narazil na pamětníky staré
              gardy. Ti mi potvrdili, že kdysi se tu hrála i hospodská liga.
              Turnaje taky, ale to už je historie stará možná dvacet, třicet
              let. Bylo jasné, že musíme začít nanovo. Inspirací mi byl i
              kamarád Marek, který v&nbsp;Lysicích úspěšně organizuje kruhové
              tréninky pro slušný počet lidí. Řekl jsem si: „Když jdou tréninky,
              proč by nešly šachy?"
            </p>

            <p>
              Přípravy jsme nepodcenili. Letáčky visely v&nbsp;pekárně,
              v&nbsp;samoobsluze i na výdejních místech balíků, další rozvěsil
              právě Marek. Díky panu starostovi, který nám umožnil použít znak
              městyse a&nbsp;akci propagoval na oficiálním webu Lysic, získal
              turnaj punc serióznosti. Hlavním lákadlem se stal „zlatý hřeb"
              turnaje – slib, že ti nejlepší si zahrají velké finále přímo v
              komnatách lysického zámku.
            </p>

            <h4>Lidový dům: Od ranní kávy až do večera</h4>

            <p>
              Den D nastal v&nbsp;sobotu 13.&nbsp;prosince. Útočiště nám poskytl
              salonek Zámecké restaurace, tzv.&nbsp;Lidový dům, kde jsme měli
              skvělé zázemí včetně tabule na zapisování výsledků. Ačkoliv jsem
              se jako organizátor-nováček zpočátku nevyhnul drobným zmatkům,
              nakonec si vše sedlo.
            </p>

            <p>
              Protože se nás sešlo devět – o tři hráče více než počet původně
              přihlášených – zvolili jsme místo systému „každý s&nbsp;každým"
              raději
              <strong>švýcarský systém</strong>. Turnaj měl i jednu unikátní
              kuriozitu – mezinárodní účast na dálku. Byl to můj otec Jozef
              Krchňavý, který tahal figurky přes telefon až ze Slovenska. Jeho
              „prodlouženou rukou" u šachovnice se stala má manželka.
            </p>

            <!-- Gallery: Lidový dům -->
            <div
              class="gallery"
              role="group"
              aria-label="Fotogalerie z turnaje v Lidovém domě"
            >
              <figure>
                <Image
                  src={g1_entry}
                  alt="Vstup do arény – salonek Lidového domu"
                  width={600}
                />
                <figcaption>Vstup do arény</figcaption>
              </figure>
              <figure>
                <Image
                  src={g1_drawing}
                  alt="Losování dalšího kola turnaje"
                  width={600}
                />
                <figcaption>Losujeme další kolo</figcaption>
              </figure>
              <figure>
                <Image
                  src={g1_players}
                  alt="U šachovnic seděli starší i mladší"
                  width={600}
                />
                <figcaption>Hráli starší i&nbsp;mladší</figcaption>
              </figure>
              <figure>
                <a
                  href="https://lichess.org/qggIXnwd/white"
                  rel="noopener noreferrer"
                  target="_blank"
                  aria-label="Analýza partie na Lichess (otevře se v novém okně)"
                >
                  <Image
                    src={g1_sweat}
                    alt="Pohled na napínavou partii – odkaz na analýzu"
                    width={600}
                  />
                </a>
                <figcaption>Tady se potili</figcaption>
              </figure>
            </div>

            <p>
              Hned po prvním kole musel bohužel ze zdravotních důvodů odstoupit
              Jirka Tichý, kterého jsem v&nbsp;rychlosti herně zastoupil já.
              Velký obdiv sklidil nejmladší účastník, teprve jedenáctiletý Josef
              Libiš. Za odvahu hrát partie mezi samými dospělými si odnesl
              figurku zlatého jezdce a&nbsp;kalendář slavných šachistů.
            </p>

            <figure class="img-float-right">
              <Image
                src={tournamentTable}
                alt="Cena pro nejmladšího hráče – zlatý jezdec"
                width={280}
              />
              <figcaption>Zlatý jezdec pro nejmladšího hráče</figcaption>
            </figure>

            <p>
              Třetí kolo turnaj systém vylosoval velmi příhodně. Šest hráčů
              tvořilo páry otec a&nbsp;syn a&nbsp;právě třetí kolo patřilo
              měření rodinných sil. Podrobné výsledky kol můžete vidět
              v&nbsp;tabulce níže.
            </p>
            <p>
              Nakonec si první dvě místa vybojovali otec a&nbsp;syn – Zdeněk
              Libiš starší a&nbsp;Zdeněk Libiš mladší. Bylo jasné, že nás čeká
              napínavé rodinné derby.
            </p>

            <div class="highlight-box">
              <p>Hrálo se tempo: <strong>Classic 30+0</strong></p>
            </div>

            <!-- Standings table -->
            <h4>Pořadí po základním kole</h4>
            <div class="table-wrapper">
              <table>
                <thead>
                  <tr>
                    <th scope="col">Pozice</th>
                    <th scope="col">Jméno</th>
                    <th scope="col">Body</th>
                  </tr>
                </thead>
                <tbody>
                  <tr
                    ><td>#1</td><td>Zdeněk L. st. (Kunštát)</td><td>4.5</td></tr
                  >
                  <tr><td>#2</td><td>Zdeněk L. ml. (Lysice)</td><td>4.5</td></tr
                  >
                  <tr><td>#3</td><td>Jozef K. (Poproč)</td><td>3</td></tr>
                  <tr><td>#4</td><td>Tomáš B. (Hamry)</td><td>2</td></tr>
                  <tr><td>#5</td><td>Robert T. (Lysice)</td><td>2</td></tr>
                  <tr><td>#6</td><td>Jozef M. (Lysice)</td><td>2</td></tr>
                  <tr><td>#7</td><td>Josef L. ml. (Lysice)</td><td>0.5</td></tr>
                  <tr><td>#8</td><td>Josef L. st. (Lysice)</td><td>0.5</td></tr>
                  <tr><td>#9</td><td>Jiří T. (Lysice)</td><td>0</td></tr>
                </tbody>
              </table>
            </div>

            <p>
              Podrobné výsledky na
              <a
                href="https://swisssystem.org/tournament/6b8d27f2d11e4a72a04a783abed7eae5/standings"
                rel="noopener noreferrer"
                target="_blank"
                aria-label="Podrobné výsledky na Swiss system (otevře se v novém okně)"
                >Swiss system</a
              >.
            </p>
            <p>
              Některé partie můžete analyzovat s&nbsp;námi:<br />
              <a
                href="https://lichess.org/PpKDaVB9/black"
                rel="noopener noreferrer"
                target="_blank"
                aria-label="2. kolo: Jozef K. vs. Zdeněk L. st. - analýza na Lichess (otevře se v novém okně)"
                >2.&nbsp;kolo: Jozef K. vs. Zdeněk L. st.</a
              ><br />
              <a
                href="https://lichess.org/qggIXnwd/white"
                rel="noopener noreferrer"
                target="_blank"
                aria-label="4. kolo: Zdeněk L. ml. vs Jozef K. - analýza na Lichess (otevře se v novém okně)"
                >4.&nbsp;kolo: Zdeněk L. ml. vs Jozef K.</a
              >
            </p>
          </div>
        </details>

        <!-- ── Zámecké finále ── -->
        <details class="archive-event">
          <summary>
            <strong>🏰 Zámecké finále – Armageddon</strong>
            <span class="archive-date">Prosinec 2025</span>
          </summary>
          <div class="archive-event__content flow-lg">
            <p>
              Zlatý hřeb celého turnaje přišel 30.&nbsp;prosince. Paní
              kastelánka nám velkoryse zpřístupnila renesanční salonek naproti
              pokladně. Temperovaná místnost, důstojné kulisy a&nbsp;připravená
              káva s&nbsp;čajem umožnily příjemné dosednutí ke „královskému
              grandfinále".
            </p>

            <!-- Gallery: Zámecké finále -->
            <div
              class="gallery"
              role="group"
              aria-label="Fotogalerie ze zámeckého finále"
            >
              <figure>
                <Image
                  src={g2_castle}
                  alt="Příchod na zámek k finále"
                  width={600}
                />
                <figcaption>Jdeme na zámek</figcaption>
              </figure>
              <figure>
                <Image
                  src={g2_kings}
                  alt="Šachová hra v zámeckém salonku"
                  width={600}
                />
                <figcaption>Hra králů</figcaption>
              </figure>
              <figure>
                <Image
                  src={g2_duel}
                  alt="Rodinný duel otce a syna na zámku"
                  width={600}
                />
                <figcaption>Rodinný duel na zámku</figcaption>
              </figure>
              <figure>
                <Image
                  src={g2_revenge}
                  alt="Revanšová partie při šachu"
                  width={600}
                />
                <figcaption>Revanš při šachu</figcaption>
              </figure>
            </div>

            <p>
              Kdo čekal jednoznačnou záležitost, mýlil se. Souboj dvou Zdeňků
              byl neuvěřitelně vyrovnaný. Po čtyřech partiích byl stav
              nerozhodný 2:2, přičemž se ukázalo, že ani jednomu z&nbsp;nich
              nebylo tempo 15 minut + 10 vteřin úplně vlastní – neviděli jsme
              ani jeden mat. O&nbsp;vítězi tak musela rozhodnout až pátá partie
              – takzvaný Armageddon. V&nbsp;tomto posledním kole si už dávali na
              čas větší pozor, ale chvilka nepozornosti pustila bílou dámu až
              nebezpečně blízko černému králi. V&nbsp;„náhlé smrti" nakonec
              zvítězila zkušenost a&nbsp;prvním novodobým šampionem se stal <strong
                >Zdeněk Libiš starší</strong
              >. Závěrečná slova „Tak a&nbsp;máš to!" už jen s&nbsp;úsměvem
              dokreslila zdravou rodinnou rivalitu.
            </p>

            <!-- Gallery: Výsledky -->
            <div
              class="gallery"
              role="group"
              aria-label="Fotogalerie z předávání cen"
            >
              <figure>
                <Image
                  src={g3_diplomas}
                  alt="Předávání diplomů vítězům"
                  width={600}
                />
                <figcaption>Byly i diplomy</figcaption>
              </figure>
              <figure>
                <Image
                  src={g3_poster}
                  alt="Turnajový plakát na památku"
                  width={600}
                />
                <figcaption>Plakát na památku</figcaption>
              </figure>
              <figure>
                <Image
                  src={g3_winner}
                  alt="Vítěz turnaje Zdeněk Libiš st."
                  width={600}
                />
                <figcaption>Nakonec zaslouženě</figcaption>
              </figure>
            </div>

            <!-- Finale results table -->
            <h4 aria-label="Výsledky zámeckého finále">Výsledky zámeckého finále</h4>
            <div class="table-wrapper" role="region" aria-label="Výsledky zámeckého finále">
              <table>
                <thead>
                  <tr>
                    <th scope="col">Hráč</th>
                    <th scope="col"
                      ><a
                        href="https://lichess.org/evUtvmUu"
                        rel="noopener noreferrer"
                        target="_blank"
                        aria-label="Partie 1 - analýza na Lichess (otevře se v novém okně)"
                        >Partie 1</a
                      ></th
                    >
                    <th scope="col"
                      ><a
                        href="https://lichess.org/dRuXlJkF"
                        rel="noopener noreferrer"
                        target="_blank"
                        aria-label="Partie 2 - analýza na Lichess (otevře se v novém okně)"
                        >Partie 2</a
                      ></th
                    >
                    <th scope="col"
                      ><a
                        href="https://lichess.org/6OB6An2Y"
                        rel="noopener noreferrer"
                        target="_blank"
