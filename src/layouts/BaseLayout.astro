---
interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="cs">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light dark" />
    <meta name="description" content={description} />
    <meta property="og:site_name" content={title} />
    <meta property="og:title" content={title} />
    <meta property="og:type" content="website" />
    <meta property="og:description" content={description} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    {/* Anti-flash theme script — runs before first paint */}
    <script is:inline>
      (function() {
        var stored = localStorage.getItem('theme');
        var btn = null;
        function getSystemTheme() {
          return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        }
        function applyTheme(mode) {
          var resolved = mode === 'auto' ? getSystemTheme() : mode;
          document.documentElement.setAttribute('data-theme', resolved);
          document.documentElement.setAttribute('data-theme-mode', mode);
        }
        applyTheme(stored || 'auto');

        // Listen for system theme changes when in auto mode
        window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', function() {
          var current = localStorage.getItem('theme') || 'auto';
          if (current === 'auto') applyTheme('auto');
        });

        // Theme toggle handler — attached after DOM is ready
        function initToggle() {
          btn = document.getElementById('theme-toggle');
          if (!btn) return;
          var mode = localStorage.getItem('theme') || 'auto';
          btn.setAttribute('data-theme-mode', mode);
          btn.addEventListener('click', function() {
            var current = localStorage.getItem('theme') || 'auto';
            var next = current === 'auto' ? 'light' : current === 'light' ? 'dark' : 'auto';
            localStorage.setItem('theme', next);
            applyTheme(next);
            btn.setAttribute('data-theme-mode', next);
          });
        }
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', initToggle, { once: true });
        } else {
          initToggle();
        }
      })();
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  /* ========================================
     CSS CUSTOM PROPERTIES — LIGHT THEME
     ======================================== */
  :root {
    --color-bg: #faf8f5;
    --color-bg-pattern-1: rgba(192, 144, 68, 0.08);
    --color-bg-pattern-2: rgba(96, 56, 16, 0.09);
    --color-text: #2e2414;
    --color-heading: #1a1206;
    --color-text-secondary: #4a3f30;
    --color-muted: #7a6f60;
    --color-accent: #8b6914;
    --color-accent-hover: #5a4510;
    --color-accent-light: #a47d1a;
    --color-border: #e8e2d8;
    --color-card-bg: #ffffff;
    --color-highlight-bg: #f5f0e8;
    --color-hero-start: #f5f0e8;
    --color-hero-end: #faf8f5;
    --color-nav-bg: rgba(250, 248, 245, 0.92);
    --color-nav-text: #5a4d3a;
    --color-badge-bg: #8b6914;
    --color-featured-start: rgba(253, 249, 240, 0.97);
    --color-featured-end: rgba(250, 248, 245, 0.97);
    --color-archive-bg: rgba(245, 240, 232, 0.6);
    --color-newsletter-bg: #1a1206;
    --color-newsletter-text: #f5f0e8;
    --color-newsletter-muted: #d4c9b4;
    --color-newsletter-accent: #d4a944;
    --color-newsletter-input-bg: #2e2414;
    --color-newsletter-input-border: #5a4d3a;
    --color-hover-bg: rgba(0, 0, 0, 0.05);
    --color-table-header-bg: #f5f0e8;
    --color-img-shadow: rgba(0, 0, 0, 0.1);
  }

  /* ========================================
     DARK THEME
     ======================================== */
  [data-theme="dark"] {
    --color-bg: #1a1a1e;
    --color-bg-pattern-1: rgba(192, 144, 68, 0.04);
    --color-bg-pattern-2: rgba(96, 56, 16, 0.05);
    --color-text: #e0dbd4;
    --color-heading: #f5f0e8;
    --color-text-secondary: #b8b0a4;
    --color-muted: #8a8278;
    --color-accent: #d4a944;
    --color-accent-hover: #e8c060;
    --color-accent-light: #c49a24;
    --color-border: #3a3530;
    --color-card-bg: #242428;
    --color-highlight-bg: #2a2520;
    --color-hero-start: #1e1e22;
    --color-hero-end: #1a1a1e;
    --color-nav-bg: rgba(26, 26, 30, 0.92);
    --color-nav-text: #b8b0a4;
    --color-badge-bg: #b8910e;
    --color-featured-start: rgba(30, 28, 24, 0.97);
    --color-featured-end: rgba(26, 26, 30, 0.97);
    --color-archive-bg: rgba(30, 28, 24, 0.6);
    --color-newsletter-bg: #111114;
    --color-newsletter-text: #e0dbd4;
    --color-newsletter-muted: #8a8278;
    --color-newsletter-accent: #d4a944;
    --color-newsletter-input-bg: #1e1e22;
    --color-newsletter-input-border: #3a3530;
    --color-hover-bg: rgba(255, 255, 255, 0.06);
    --color-table-header-bg: #2a2520;
    --color-img-shadow: rgba(0, 0, 0, 0.3);
  }

  /* ========================================
     RESET & BASE
     ======================================== */
  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    scroll-behavior: smooth;
    -webkit-text-size-adjust: 100%;
  }

  body {
    font-family:
      "Source Sans 3",
      "Source Sans Pro",
      system-ui,
      -apple-system,
      sans-serif;
    font-size: 1.125rem;
    line-height: 1.7;
    color: var(--color-text);
    background-color: var(--color-bg);
    background-image: repeating-conic-gradient(
      var(--color-bg-pattern-1) 0% 25%,
      var(--color-bg-pattern-2) 0% 50%
    );
    background-size: 100px 100px;
    transition: background-color 0.3s, color 0.3s;
  }

  img {
    display: block;
    max-width: 100%;
    height: auto;
  }

  a {
    color: var(--color-accent);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 0.15em;
    transition: color 0.2s ease;
  }

  a:hover,
  a:focus-visible {
    color: var(--color-accent-hover);
  }

  /* ========================================
     TYPOGRAPHY — unified scale
     ======================================== */
  h1,
  h2,
  h3 {
    font-weight: 700;
    line-height: 1.25;
    color: var(--color-heading);
    text-wrap: balance;
  }

  h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    letter-spacing: -0.02em;
  }

  h2 {
    font-size: clamp(1.5rem, 3.5vw, 2.25rem);
    letter-spacing: -0.01em;
  }

  h3 {
    font-size: clamp(1.15rem, 2.5vw, 1.5rem);
  }

  p {
    max-width: 65ch;
  }

  strong {
    font-weight: 600;
  }

  em {
    font-style: italic;
  }

  /* ========================================
     LAYOUT UTILITIES
     ======================================== */
  .container {
    width: 100%;
    max-width: 52rem;
    margin-inline: auto;
    padding-inline: 1.5rem;
  }

  .section {
    padding-block: 4rem;
  }

  .section + .section {
    border-top: 1px solid var(--color-border);
  }

  .flow > * + * {
    margin-top: 1.25rem;
  }

  .flow-lg > * + * {
    margin-top: 2rem;
  }

  /* ========================================
     HEADER / HERO
     ======================================== */
  .hero {
    text-align: center;
    padding-block: 5rem 3rem;
    background: linear-gradient(180deg, var(--color-hero-start) 0%, var(--color-hero-end) 100%);
  }

  .hero__logo {
    margin-inline: auto;
    width: clamp(8rem, 20vw, 12rem);
    border-radius: 1rem;
  }

  .hero__title {
    margin-top: 1.5rem;
  }

  .hero__subtitle {
    margin-top: 0.75rem;
    font-weight: 400;
    color: var(--color-nav-text);
  }

  .hero__desc {
    margin-top: 1.25rem;
    margin-inline: auto;
    color: var(--color-text-secondary);
  }

  /* ========================================
     NAVIGATION
     ======================================== */
  .site-nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--color-nav-bg);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--color-border);
  }

  .site-nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding-block: 0.75rem;
    flex-wrap: wrap;
  }

  .site-nav__brand {
    font-weight: 700;
    font-size: 1.1rem;
    color: var(--color-heading);
    text-decoration: none;
  }

  .site-nav__links {
    display: flex;
    gap: 1.5rem;
    list-style: none;
  }

  .site-nav__links a {
    font-size: 0.95rem;
    text-decoration: none;
    color: var(--color-nav-text);
  }

  .site-nav__links a:hover,
  .site-nav__links a:focus-visible {
    color: var(--color-accent);
  }

  /* ========================================
     CARDS / SECTIONS
     ======================================== */
  .card {
    background: var(--color-card-bg);
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    padding: 2rem;
  }

  .highlight-box {
    background: var(--color-highlight-bg);
    border-left: 4px solid var(--color-accent);
    border-radius: 0 0.5rem 0.5rem 0;
    padding: 1.25rem 1.5rem;
  }

  /* ========================================
     FLOAT IMAGE (right)
     ======================================== */
  .img-float-right {
    float: right;
    margin: 0.25rem 0 1.25rem 2rem;
    width: clamp(180px, 35%, 280px);
    border-radius: 0.75rem;
    overflow: hidden;
    box-shadow: 0 4px 16px var(--color-img-shadow);
    clear: right;
  }

  .img-float-right img {
    width: 100%;
    height: auto;
    display: block;
  }

  .img-float-right figcaption {
    padding: 0.4rem 0.75rem 0.5rem;
    font-size: 0.8rem;
    color: var(--color-muted);
    text-align: center;
    background: var(--color-highlight-bg);
  }

  .clearfix::after {
    content: "";
    display: table;
    clear: both;
  }

  /* ========================================
     GALLERY
     ======================================== */
  .gallery {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 16rem), 1fr));
    gap: 1rem;
  }

  .gallery figure {
    position: relative;
    overflow: hidden;
    border-radius: 0.5rem;
  }

  .gallery img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    border-radius: 0.5rem;
  }

  .gallery figcaption {
    margin-top: 0.4rem;
    font-size: 0.85rem;
    color: var(--color-muted);
    text-align: center;
  }

  /* ========================================
     TABLES
     ======================================== */
  .table-wrapper {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.95rem;
  }

  th,
  td {
    padding: 0.6rem 0.85rem;
    text-align: left;
    border-bottom: 1px solid var(--color-border);
  }

  th {
    font-weight: 600;
    background: var(--color-table-header-bg);
    color: var(--color-heading);
    white-space: nowrap;
  }

  th a {
    color: inherit;
  }

  tr:last-child td {
    border-bottom: none;
  }

  /* ========================================
     LISTS
     ======================================== */
  .steps {
    list-style: decimal;
    padding-left: 1.5rem;
  }

  .steps li + li {
    margin-top: 0.5rem;
  }

  /* ========================================
     FORM (newsletter)
     ======================================== */
  .newsletter {
    background: var(--color-newsletter-bg);
    color: var(--color-newsletter-text);
    padding-block: 3.5rem;
  }

  .newsletter h2 {
    color: var(--color-newsletter-text);
  }

  .newsletter p {
    color: var(--color-newsletter-muted);
  }

  .newsletter a {
    color: var(--color-newsletter-accent);
  }

  .newsletter__form {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    max-width: 28rem;
  }

  .newsletter__form input[type="email"],
  .newsletter__form input[type="text"] {
    padding: 0.7rem 1rem;
    border: 1px solid var(--color-newsletter-input-border);
    border-radius: 0.4rem;
    background: var(--color-newsletter-input-bg);
    color: var(--color-newsletter-text);
    font-size: 1rem;
    font-family: inherit;
  }

  .newsletter__form input::placeholder {
    color: #8a7d6a;
  }

  .newsletter__form label {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    font-size: 0.85rem;
    color: #a89c88;
    cursor: pointer;
  }

  .newsletter__form input[type="checkbox"] {
    margin-top: 0.2rem;
    accent-color: var(--color-accent);
  }

  .newsletter__form button {
    padding: 0.75rem 1.5rem;
    border: none;
    border-radius: 0.4rem;
    background: var(--color-accent);
    color: #fff;
    font-size: 1rem;
    font-weight: 600;
    font-family: inherit;
    cursor: pointer;
    transition: background 0.2s ease;
    align-self: flex-start;
  }

  .newsletter__form button:hover,
  .newsletter__form button:focus-visible {
    background: var(--color-accent-light);
  }

  /* ========================================
     FOOTER
     ======================================== */
  .site-footer {
    text-align: center;
    padding-block: 2rem;
    font-size: 0.85rem;
    color: var(--color-muted);
    border-top: 1px solid var(--color-border);
  }

  .site-footer__links {
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    list-style: none;
    margin-top: 0.5rem;
  }

  .site-footer__links a {
    color: var(--color-muted);
    text-decoration: none;
  }

  .site-footer__links a:hover {
    color: var(--color-accent);
  }

  /* ========================================
     BADGE
     ======================================== */
  .badge {
    display: inline-block;
    background: var(--color-badge-bg);
    color: #fff;
    padding: 0.35rem 1.15rem;
    border-radius: 2rem;
    font-size: 0.9rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    margin-bottom: 0.5rem;
  }

  /* ========================================
     FEATURED SECTION (current tournament)
     ======================================== */
  .section--featured {
    background:
      linear-gradient(
        180deg,
        var(--color-featured-start) 0%,
        var(--color-featured-end) 100%
      ),
      repeating-conic-gradient(
        var(--color-bg-pattern-1) 0% 25%,
        var(--color-bg-pattern-2) 0% 50%
      );
    background-size:
      auto,
      100px 100px;
    border-top: 3px solid var(--color-accent);
    position: relative;
  }

  /* ========================================
     TOURNAMENT HERO IMAGE (full-width)
     ======================================== */
  .tournament-hero-img {
    border-radius: 1rem;
    overflow: hidden;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.14);
    margin: 0;
  }

  .tournament-hero-img img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 0;
  }

  /* ========================================
     INFO CARD
     ======================================== */
  .info-card {
    background: var(--color-card-bg);
    border: 2px solid var(--color-border);
    border-radius: 1rem;
    padding: 2rem;
  }

  .info-card h3 {
    margin-bottom: 1rem;
  }

  .info-card--action {
    border-color: var(--color-accent);
    background: linear-gradient(135deg, var(--color-highlight-bg) 0%, var(--color-card-bg) 100%);
  }

  .info-card__list {
    display: grid;
    gap: 0.75rem;
  }

  .info-card__item {
    display: flex;
    gap: 0.75rem;
    align-items: baseline;
  }

  .info-card__item dt {
    font-weight: 600;
    min-width: 5.5rem;
    white-space: nowrap;
  }

  .info-card__item dd {
    font-size: 1.05rem;
  }

  /* ========================================
     CTA TEXT
     ======================================== */
  .cta-text {
    font-size: 1.15rem;
    text-align: center;
    max-width: 45ch;
    margin-inline: auto;
    padding: 1.5rem;
    background: linear-gradient(135deg, var(--color-highlight-bg) 0%, var(--color-card-bg) 100%);
    border-radius: 0.75rem;
    border: 1px solid var(--color-border);
  }

  .section--archive {
    background: var(--color-archive-bg);
  }

  .section-lead {
    color: var(--color-nav-text);
    font-size: 1.1rem;
    margin-bottom: 1rem;
  }

  /* ========================================
     RESPONSIVE
     ======================================== */
  @media (max-width: 40rem) {
    .section {
      padding-block: 2.5rem;
    }

    .hero {
      padding-block: 3rem 2rem;
    }

    .card {
      padding: 1.25rem;
    }

    .site-nav__links {
      gap: 1rem;
      font-size: 0.85rem;
    }

    .info-card {
      padding: 1.25rem;
    }

    .img-float-right {
      float: none;
      width: 100%;
      margin: 0 0 1.25rem 0;
    }
  }

  /* ========================================
     FONT LOADING (self-hosted via Google CDN)
     ======================================== */
  @font-face {
    font-family: "Source Sans 3";
    font-style: normal;
    font-weight: 300 900;
    font-display: swap;
    src: url("https://fonts.gstatic.com/s/sourcesans3/v19/nwpStKy2OAdR1K-IwhWudF-R3wEaZfrc.woff2")
      format("woff2");
    unicode-range:
      U+0100-02BA, U+02BD-02C5, U+02C7-02CC, U+02CE-02D7, U+02DD-02FF, U+0304,
      U+0308, U+0329, U+1D00-1DBF, U+1E00-1E9F, U+1EF2-1EFF, U+2020,
      U+20A0-20AB, U+20AD-20C0, U+2113, U+2C60-2C7F, U+A720-A7FF;
  }
  @font-face {
    font-family: "Source Sans 3";
    font-style: normal;
    font-weight: 300 900;
    font-display: swap;
    src: url("https://fonts.gstatic.com/s/sourcesans3/v19/nwpStKy2OAdR1K-IwhWudF-R3w8aZQ.woff2")
      format("woff2");
    unicode-range:
      U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC,
      U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193,
      U+2212, U+2215, U+FEFF, U+FFFD;
  }

  /* Print */
  @media print {
    .site-nav,
    .newsletter {
      display: none;
    }
  }
</style>
