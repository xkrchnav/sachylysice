---
/**
 * ThemeToggle — sun/moon toggle with auto-detect and localStorage persistence.
 * Cycles: auto → light → dark → auto
 */
---

<button
  id="theme-toggle"
  class="theme-toggle"
  type="button"
  aria-label="Přepnout světlý/tmavý režim"
  title="Přepnout světlý/tmavý režim"
>
  <span class="theme-toggle__icon theme-toggle__icon--light">☀️</span>
  <span class="theme-toggle__icon theme-toggle__icon--dark">🌙</span>
  <span class="theme-toggle__icon theme-toggle__icon--auto">🌗</span>
</button>

<style>
  .theme-toggle {
    background: none;
    border: 1px solid var(--color-border, #e8e2d8);
    border-radius: 0.4rem;
    padding: 0.3rem 0.5rem;
    cursor: pointer;
    font-size: 1.1rem;
    line-height: 1;
    transition: background 0.2s, border-color 0.2s;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .theme-toggle:hover {
    background: var(--color-hover-bg, rgba(0, 0, 0, 0.05));
  }

  .theme-toggle__icon {
    display: none;
  }

  /* Show the correct icon based on active theme.
     JS sets data-theme-mode on the button. */
  [data-theme-mode="light"] .theme-toggle__icon--light {
    display: inline;
  }

  [data-theme-mode="dark"] .theme-toggle__icon--dark {
    display: inline;
  }

  [data-theme-mode="auto"] .theme-toggle__icon--auto {
    display: inline;
  }
</style>
