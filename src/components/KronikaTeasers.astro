---
/**
 * KronikaTeasers — shows the latest 3 kronika posts as clickable cards.
 */
import { getCollection } from "astro:content";
import { Image } from "astro:assets";

const posts = (await getCollection("kronika"))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);
---

<section id="kronika" class="section section--archive" aria-labelledby="kronika-title">
  <div class="container flow-lg">
    <h2 id="kronika-title">Z kroniky</h2>
    <p class="section-lead">
      Ohlédněte se s&nbsp;námi za tím, co už máme za sebou.
    </p>

    <div class="teaser-grid">
      {posts.map((post) => (
        <a href={`/kronika/${post.id}`} class="teaser-card">
          <figure class="teaser-card__img">
            <Image
              src={post.data.photo}
              alt={post.data.title}
              width={400}
              height={267}
            />
          </figure>
          <div class="teaser-card__body">
            <time datetime={post.data.date.toISOString()}>
              {post.data.date.toLocaleDateString("cs-CZ", {
                year: "numeric",
                month: "long",
              })}
            </time>
            <h3>{post.data.title}</h3>
            <p>{post.data.intro}</p>
            <span class="teaser-card__link">Číst dále →</span>
          </div>
        </a>
      ))}
    </div>

    <p style="text-align: center; margin-top: 2rem;">
      <a href="/kronika" class="all-kronika-link">Zobrazit celou kroniku →</a>
    </p>
  </div>
</section>

<style>
  .teaser-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  @media (min-width: 48rem) {
    .teaser-grid {
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    }
  }

  .teaser-card {
    display: flex;
    flex-direction: column;
    background: var(--color-card-bg, #fff);
    border: 1px solid var(--color-border, #e8e2d8);
    border-radius: 0.75rem;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: box-shadow 0.2s, transform 0.15s;
  }

  .teaser-card:hover {
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.1);
    transform: translateY(-2px);
  }

  .teaser-card__img {
    margin: 0;
    overflow: hidden;
  }

  .teaser-card__img img {
    width: 100%;
    aspect-ratio: 3 / 2;
    object-fit: cover;
  }

  .teaser-card__body {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    flex: 1;
  }

  .teaser-card__body time {
    font-size: 0.8rem;
    color: var(--color-muted, #7a6f60);
    text-transform: capitalize;
  }

  .teaser-card__body h3 {
    font-size: 1.1rem;
    line-height: 1.3;
    color: var(--color-heading, #1a1206);
  }

  .teaser-card__body p {
    font-size: 0.9rem;
    color: var(--color-text-secondary, #4a3f30);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .teaser-card__link {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-accent, #8b6914);
    margin-top: auto;
    padding-top: 0.5rem;
  }

  .all-kronika-link {
    font-weight: 600;
    color: var(--color-accent, #8b6914);
    font-size: 1rem;
  }
</style>
