---
/**
 * ResultsTable — styled table wrapper for tournament results in MDX.
 * Usage: <ResultsTable title="Pořadí">
 *          <table>...</table>
 *        </ResultsTable>
 */
interface Props {
  title?: string;
}

const { title } = Astro.props;
---

{title && <h4>{title}</h4>}
<div class="table-wrapper" role="region" aria-label={title ?? 'Výsledky'}>
  <slot />
</div>
